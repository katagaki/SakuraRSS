    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura verwendet deinen Standort, um auf dem Heute-Tab das lokale Wetter anzuzeigen. Der Standort wird ausschließlich an Apple Wetter gesendet und nicht auf unseren Servern gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura uses your location to show local weather on the Today tab. The location is sent only to Apple Weather and is never stored on our servers."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura utilise votre position pour afficher la météo locale dans l’onglet Aujourd’hui. Elle est uniquement envoyée à Apple Météo et n’est jamais conservée sur nos serveurs."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura usa la tua posizione per mostrare il meteo locale nella scheda Oggi. La posizione viene inviata solo ad Apple Meteo e non viene mai memorizzata sui nostri server."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サクラは「Today」タブにローカルの天気を表示するために位置情報を使用します。位置情報はApple天気にのみ送信され、当社のサーバーには保存されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura는 Today 탭에 현지 날씨를 표시하기 위해 위치 정보를 사용합니다. 위치 정보는 Apple 날씨에만 전송되며, 자체 서버에는 저장되지 않습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura sử dụng vị trí của bạn để hiển thị thời tiết tại địa phương trong tab Today. Vị trí chỉ được gửi đến Apple Weather và không bao giờ được lưu trên máy chủ của chúng tôi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura 使用您的位置，在「Today」标签页中显示本地天气。位置仅会发送至 Apple 天气，绝不会存储在我们的服务器上。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura 使用您的位置，在「Today」分頁中顯示本地天氣。位置僅會傳送至 Apple 天氣，絕不會儲存在我們的伺服器上。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Additions Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sakura kann Bilder in deiner Fotomediathek speichern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Sakura can save images in feed articles to your Photo Library."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sakura peut enregistrer des images dans votre photothèque."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sakura può salvare immagini nella tua libreria foto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "サクラは画像を写真ライブラリに保存できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sakura는 이미지를 사진 보관함에 저장할 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sakura có thể lưu hình ảnh vào Thư viện ảnh của bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sakura 可以将图片保存到您的照片图库。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sakura 可以將圖片儲存到你的照片圖庫。"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Privacy - Speech Recognition Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura verwendet die geräteinterne Spracherkennung, um heruntergeladene Podcast-Episoden zu transkribieren. Die Audioverarbeitung erfolgt lokal und verlässt Ihr Gerät nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Sakura uses on-device speech recognition to transcribe podcast episodes you download. Audio is processed locally and never leaves your device."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura utilise la reconnaissance vocale sur l'appareil pour transcrire les épisodes de podcast que vous téléchargez. L'audio est traité localement et ne quitte jamais votre appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura utilizza il riconoscimento vocale sul dispositivo per trascrivere gli episodi podcast scaricati. L'audio viene elaborato localmente e non lascia mai il dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サクラはダウンロードしたポッドキャストエピソードの文字起こしにデバイス上の音声認識を使用します。音声はデバイス上でローカルに処理され、外部に送信されることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura는 다운로드한 팟캐스트 에피소드를 전사하기 위해 기기 내 음성 인식을 사용합니다. 오디오는 로컬에서 처리되며 기기를 떠나지 않습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura sử dụng nhận dạng giọng nói trên thiết bị để chép lời các tập podcast bạn tải xuống. Âm thanh được xử lý cục bộ và không bao giờ rời khỏi thiết bị của bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura 使用设备端语音识别来转录您下载的播客单集。音频在本地处理，不会离开您的设备。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakura 使用裝置端語音辨識來轉錄您下載的Podcast單集。音訊在本機處理，不會離開您的裝置。"
          }
        }
      }
    },
