    "Instagram.HideReels.Footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, werden Reels aus Instagram-Feeds ausgeblendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, reels will be hidden from Instagram feeds."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activée, les Reels seront masqués des flux Instagram."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando attivato, i Reel verranno nascosti dai feed di Instagram."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、Instagramフィードからリールが非表示になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성화하면 Instagram 피드에서 릴이 숨겨집니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Khi bật, reels sẽ bị ẩn khỏi nguồn cấp Instagram."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用后，Reels 将从 Instagram 订阅源中隐藏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用後，Reels 將從 Instagram 訂閱源中隱藏。"
          }
        }
      }
    },
