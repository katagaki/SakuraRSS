        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No RSS feed was found. Petal can build one on-device by scraping the page with selectors you choose."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun flux RSS trouvé. Petal peut en créer un sur l’appareil en analysant la page avec les sélecteurs de votre choix."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun feed RSS trovato. Petal può crearne uno sul dispositivo analizzando la pagina con i selettori che scegli."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "RSSフィードが見つかりませんでした。Petalはあなたが選んだセレクタでページをスクレイピングし、デバイス上でフィードを作成できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "RSS 피드를 찾을 수 없습니다. Petal이 선택한 선택자로 페이지를 스크레이핑하여 기기에서 피드를 만들 수 있습니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không tìm thấy nguồn RSS. Petal có thể tạo một nguồn ngay trên thiết bị bằng cách trích xuất trang với các bộ chọn bạn chọn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到 RSS 订阅源。Petal 可以使用你选择的选择器在设备上抓取该页面并生成订阅源。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到 RSS 訂閱源。Petal 可以使用你選擇的選擇器在裝置上抓取該頁面並產生訂閱源。"
          }
        }
      }
    },
