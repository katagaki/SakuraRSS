    "Onboarding.Sample.Summary3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I ranked all 24 onigiri flavors at FamilyStop from worst to best. Number one will surprise you!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "FamilyStopのおにぎり全24種類をワーストからベストまでランキング。1位は意外なあの味！"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我把FamilyStop的24种饭团口味从最差到最好排了个名。第一名会让你大吃一惊！"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我把FamilyStop的24種飯糰口味從最差到最好排了個名。第一名會讓你大吃一驚！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "FamilyStop의 주먹밥 24종을 최악부터 최고까지 랭킹했습니다. 1위는 놀라울 겁니다!"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tôi đã xếp hạng tất cả 24 vị onigiri tại FamilyStop từ dở nhất đến ngon nhất. Số một sẽ khiến bạn bất ngờ!"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich habe alle 24 Onigiri-Sorten bei FamilyStop von schlecht bis gut bewertet. Platz eins wird euch überraschen!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'ai classé les 24 saveurs d'onigiri chez FamilyStop du pire au meilleur. Le numéro un va vous surprendre !"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ho classificato tutti i 24 gusti di onigiri al FamilyStop dal peggiore al migliore. Il numero uno vi sorprenderà!"
          }
        }
      }
    },
