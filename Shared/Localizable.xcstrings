    "Onboarding.Step.BackgroundRefresh.Description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your feeds fresh with automatic background updates."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックグラウンド更新でフィードを常に最新に保ちます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过自动后台更新保持订阅源最新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透過自動背景更新保持訂閱來源最新。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동 백그라운드 업데이트로 피드를 최신 상태로 유지합니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ nguồn cấp dữ liệu luôn mới với cập nhật nền tự động."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte deine Feeds mit automatischen Hintergrund-Updates aktuell."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez vos flux à jour grâce aux mises à jour automatiques en arrière-plan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantieni i tuoi feed aggiornati con gli aggiornamenti automatici in background."
          }
        }
      }
