    "Onboarding.Step.AppleIntelligence.Description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get smart daily summaries of your feeds powered by Apple Intelligence."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligenceを活用して、フィードのスマートな日次まとめを受け取りましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "利用 Apple Intelligence 获取订阅源的智能每日摘要。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "利用 Apple Intelligence 取得訂閱來源的智慧每日摘要。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence로 피드의 스마트 일일 요약을 받아보세요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhận bản tóm tắt hàng ngày thông minh từ nguồn cấp dữ liệu nhờ Apple Intelligence."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erhalte smarte tägliche Zusammenfassungen deiner Feeds mit Apple Intelligence."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recevez des résumés quotidiens intelligents de vos flux grâce à Apple Intelligence."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricevi riassunti giornalieri intelligenti dei tuoi feed grazie ad Apple Intelligence."
          }
        }
      }
    }
