    "Labs.Warning %@" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Labs-Funktionen können dazu führen, dass %@ langsamer wird oder abstürzt. Wenn die App beim Start abstürzt, werden alle Labs-Funktionen automatisch deaktiviert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Labs features may cause %@ to slow down or crash. If the app crashes on startup, all labs features will be turned off automatically."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les fonctionnalités Labs peuvent ralentir ou faire planter %@. Si l'application plante au démarrage, toutes les fonctionnalités Labs seront automatiquement désactivées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le funzionalità Labs possono causare rallentamenti o arresti anomali di %@. Se l'app si arresta all'avvio, tutte le funzionalità Labs verranno disattivate automaticamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ラボ機能により、%@が遅くなったりクラッシュしたりする可能性があります。起動時にアプリがクラッシュした場合、すべてのラボ機能は自動的にオフになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "실험실 기능으로 인해 %@이(가) 느려지거나 충돌할 수 있습니다. 앱이 시작 시 충돌하면 모든 실험실 기능이 자동으로 꺼집니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các tính năng Phòng thí nghiệm có thể khiến %@ chậm lại hoặc bị lỗi. Nếu ứng dụng bị lỗi khi khởi động, tất cả tính năng Phòng thí nghiệm sẽ tự động được tắt."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "实验室功能可能会导致%@变慢或崩溃。如果应用在启动时崩溃，所有实验室功能将自动关闭。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "實驗室功能可能會導致%@變慢或當機。如果應用程式在啟動時當機，所有實驗室功能將自動關閉。"
          }
        }
      }
    },
