    },
    "Onboarding.Sample.Title1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit unveils the Passionfruit Phone 20 with holographic display"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit、ホログラフィックディスプレイ搭載のPassionfruit Phone 20を発表"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit发布搭载全息显示屏的Passionfruit Phone 20"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit發表搭載全息顯示器的Passionfruit Phone 20"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit, 홀로그래픽 디스플레이 탑재 Passionfruit Phone 20 공개"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit ra mắt Passionfruit Phone 20 với màn hình holographic"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit stellt das Passionfruit Phone 20 mit holografischem Display vor"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit dévoile le Passionfruit Phone 20 avec écran holographique"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit presenta il Passionfruit Phone 20 con display olografico"
          }
        }
      }
    },
    "Onboarding.Sample.Summary1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The latest Passionfruit Phone features a revolutionary holographic display and the fastest chip ever in a smartphone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最新のPassionfruit Phoneは革新的なホログラフィックディスプレイとスマートフォン史上最速のチップを搭載。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最新款Passionfruit Phone搭载革命性全息显示屏和智能手机史上最快芯片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "最新款Passionfruit Phone搭載革命性全息顯示器和智慧型手機史上最快晶片。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최신 Passionfruit Phone은 혁신적인 홀로그래픽 디스플레이와 스마트폰 역사상 가장 빠른 칩을 탑재했습니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Passionfruit Phone mới nhất trang bị màn hình holographic cách mạng và chip nhanh nhất từ trước đến nay."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das neueste Passionfruit Phone bietet ein revolutionäres holografisches Display und den schnellsten Chip aller Zeiten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le dernier Passionfruit Phone est doté d'un écran holographique révolutionnaire et de la puce la plus rapide jamais vue."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'ultimo Passionfruit Phone presenta un rivoluzionario display olografico e il chip più veloce di sempre."
          }
        }
      }
    },
