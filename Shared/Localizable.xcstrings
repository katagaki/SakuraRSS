    "AddFeed.Section.SearchFooter": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a feed URL, website URL, or domain. Sakura will try the URL as a feed first, then search the page for feeds, then search the root domain."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィードURL、ウェブサイトURL、またはドメインを入力してください。SakuraはまずURLをフィードとして試し、次にページ内のフィードを検索し、最後にルートドメインを検索します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入订阅源 URL、网站 URL 或域名。Sakura 会先尝试将 URL 作为订阅源，然后搜索页面中的订阅源，最后搜索根域名。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輸入訂閱源 URL、網站 URL 或網域。Sakura 會先嘗試將 URL 作為訂閱源，接著搜尋頁面中的訂閱源，最後搜尋根網域。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피드 URL, 웹사이트 URL 또는 도메인을 입력하세요. Sakura가 먼저 해당 URL을 피드로 시도한 다음, 페이지에서 피드를 검색하고, 마지막으로 루트 도메인을 검색합니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhập URL nguồn cấp, URL trang web, hoặc tên miền. Sakura sẽ thử URL như một nguồn cấp trước, sau đó tìm nguồn cấp trên trang, rồi tìm trên tên miền gốc."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geben Sie eine Feed-URL, Website-URL oder Domain ein. Sakura versucht die URL zuerst als Feed, durchsucht dann die Seite nach Feeds und anschließend die Hauptdomain."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrez une URL de flux, une URL de site web ou un domaine. Sakura essaiera d'abord l'URL comme flux, puis cherchera des flux dans la page, puis dans le domaine racine."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci un URL di feed, un URL di sito web o un dominio. Sakura proverà prima l'URL come feed, poi cercherà feed nella pagina, poi nel dominio principale."
          }
        }
      }
    },
