    "Onboarding.Sample.Title2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "First AI successfully calculates 1 + 1 in landmark achievement"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AI、画期的な成果として1 + 1の計算に初めて成功"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "人工智能首次成功计算1 + 1，成为里程碑式成就"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "人工智慧首次成功計算1 + 1，成為里程碑式成就"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI, 획기적인 성과로 1 + 1 계산에 최초 성공"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "AI đầu tiên tính toán thành công 1 + 1 trong thành tựu mang tính bước ngoặt"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erste KI berechnet erfolgreich 1 + 1 in bahnbrechendem Durchbruch"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une IA calcule avec succès 1 + 1 pour la première fois, une avancée historique"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La prima IA calcola con successo 1 + 1 in un traguardo storico"
          }
        }
      }
    },
    "Onboarding.Sample.Summary2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Researchers celebrate as their neural network returns the correct answer after years of training on advanced mathematics."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "研究者たちは、高度な数学の長年のトレーニングの末、ニューラルネットワークが正解を返したことを祝福。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "经过多年高等数学训练后，研究人员的神经网络终于给出了正确答案，团队欢庆这一突破。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "經過多年高等數學訓練後，研究人員的神經網路終於給出了正確答案，團隊歡慶這一突破。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연구자들은 수년간의 고급 수학 훈련 끝에 신경망이 정답을 반환한 것을 축하했습니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các nhà nghiên cứu ăn mừng khi mạng nơ-ron của họ trả về đáp án đúng sau nhiều năm huấn luyện toán cao cấp."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Forscher feiern, als ihr neuronales Netz nach jahrelangem Training die richtige Antwort liefert."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les chercheurs célèbrent le moment où leur réseau neuronal donne la bonne réponse après des années d'entraînement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I ricercatori festeggiano quando la loro rete neurale restituisce la risposta corretta dopo anni di addestramento."
          }
        }
      }
    },
