    "Onboarding.Sample.Summary1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das neueste Passionfruit Phone bietet ein revolutionäres holografisches Display und den schnellsten Chip aller Zeiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The latest Passionfruit Phone features a revolutionary holographic display and the fastest chip ever in a smartphone."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le dernier Passionfruit Phone est doté d'un écran holographique révolutionnaire et de la puce la plus rapide jamais vue."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'ultimo Passionfruit Phone presenta un rivoluzionario display olografico e il chip più veloce di sempre."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最新のPassionfruit Phoneは革新的なホログラフィックディスプレイとスマートフォン史上最速のチップを搭載。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최신 Passionfruit Phone은 혁신적인 홀로그래픽 디스플레이와 스마트폰 역사상 가장 빠른 칩을 탑재했습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passionfruit Phone mới nhất trang bị màn hình holographic cách mạng và chip nhanh nhất từ trước đến nay."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最新款Passionfruit Phone搭载革命性全息显示屏和智能手机史上最快芯片。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最新款Passionfruit Phone搭載革命性全息顯示器和智慧型手機史上最快晶片。"
          }
        }
      }
    },
    "Onboarding.Sample.Summary2" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forscher feiern, als ihr neuronales Netz nach jahrelangem Training die richtige Antwort liefert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Researchers celebrate as their neural network returns the correct answer after years of training on advanced mathematics."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les chercheurs célèbrent le moment où leur réseau neuronal donne la bonne réponse après des années d'entraînement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I ricercatori festeggiano quando la loro rete neurale restituisce la risposta corretta dopo anni di addestramento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "研究者たちは、高度な数学の長年のトレーニングの末、ニューラルネットワークが正解を返したことを祝福。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "연구자들은 수년간의 고급 수학 훈련 끝에 신경망이 정답을 반환한 것을 축하했습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các nhà nghiên cứu ăn mừng khi mạng nơ-ron của họ trả về đáp án đúng sau nhiều năm huấn luyện toán cao cấp."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "经过多年高等数学训练后，研究人员的神经网络终于给出了正确答案，团队欢庆这一突破。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "經過多年高等數學訓練後，研究人員的神經網路終於給出了正確答案，團隊歡慶這一突破。"
          }
        }
      }
    },
    "Onboarding.Sample.Summary3" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ich habe alle 24 Onigiri-Sorten bei FamilyStop von schlecht bis gut bewertet. Platz eins wird euch überraschen!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I ranked all 24 onigiri flavors at FamilyStop from worst to best. Number one will surprise you!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "J'ai classé les 24 saveurs d'onigiri chez FamilyStop du pire au meilleur. Le numéro un va vous surprendre !"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ho classificato tutti i 24 gusti di onigiri al FamilyStop dal peggiore al migliore. Il numero uno vi sorprenderà!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "FamilyStopのおにぎり全24種類をワーストからベストまでランキング。1位は意外なあの味！"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "FamilyStop의 주먹밥 24종을 최악부터 최고까지 랭킹했습니다. 1위는 놀라울 겁니다!"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tôi đã xếp hạng tất cả 24 vị onigiri tại FamilyStop từ dở nhất đến ngon nhất. Số một sẽ khiến bạn bất ngờ!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我把FamilyStop的24种饭团口味从最差到最好排了个名。第一名会让你大吃一惊！"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我把FamilyStop的24種飯糰口味從最差到最好排了個名。第一名會讓你大吃一驚！"
          }
        }
      }
    },
