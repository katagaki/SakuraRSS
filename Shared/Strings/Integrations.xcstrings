    "Petal.Footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wandle beliebige Webseiten mit geräteinternem Scraping in RSS-Feeds um. Ideal für Blogs und Single-Page-Apps, die keinen eigenen Feed anbieten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Turn any webpage into an RSS feed using on-device scraping. Useful for blogs and single-page apps that don't publish their own feed."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transformez n'importe quelle page web en flux RSS grâce à un scraping effectué sur l'appareil. Pratique pour les blogs et les applications à page unique qui ne publient pas leur propre flux."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trasforma qualsiasi pagina web in un feed RSS usando uno scraping eseguito sul dispositivo. Utile per blog e app a pagina singola che non pubblicano un feed proprio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デバイス上のスクレイピングで任意のWebページをRSSフィードに変換できます。独自のフィードを提供していないブログやシングルページアプリに便利です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기기 내 스크레이핑으로 어떤 웹페이지든 RSS 피드로 바꿀 수 있습니다. 자체 피드를 제공하지 않는 블로그나 싱글 페이지 앱에 유용합니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biến bất kỳ trang web nào thành nguồn RSS bằng cách trích xuất dữ liệu ngay trên thiết bị. Hữu ích cho các blog và ứng dụng một trang không cung cấp nguồn cấp riêng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过设备端抓取，将任意网页转换为 RSS 订阅源。适用于没有自带订阅源的博客和单页应用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "透過裝置端抓取，將任意網頁轉換為 RSS 訂閱源。適用於沒有自帶訂閱源的部落格和單頁應用。"
          }
        }
      }
    },
