    "Petal.Footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wandle beliebige Webseiten mit gerГӨteinternem Scraping in RSS-Feeds um. Ideal fГјr Blogs und Single-Page-Apps, die keinen eigenen Feed anbieten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn any webpage into an RSS feed using on-device scraping. Useful for blogs and single-page apps that don't publish their own feed."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Transformez n'importe quelle page web en flux RSS grГўce Г  un scraping effectuГ© sur l'appareil. Pratique pour les blogs et les applications Г  page unique qui ne publient pas leur propre flux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trasforma qualsiasi pagina web in un feed RSS usando uno scraping eseguito sul dispositivo. Utile per blog e app a pagina singola che non pubblicano un feed proprio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гғҮгғҗгӮӨгӮ№дёҠгҒ®гӮ№гӮҜгғ¬гӮӨгғ”гғігӮ°гҒ§д»»ж„ҸгҒ®WebгғҡгғјгӮёгӮ’RSSгғ•гӮЈгғјгғүгҒ«еӨүжҸӣгҒ§гҒҚгҒҫгҒҷгҖӮзӢ¬иҮӘгҒ®гғ•гӮЈгғјгғүгӮ’жҸҗдҫӣгҒ—гҒҰгҒ„гҒӘгҒ„гғ–гғӯгӮ°гӮ„гӮ·гғігӮ°гғ«гғҡгғјгӮёгӮўгғ—гғӘгҒ«дҫҝеҲ©гҒ§гҒҷгҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "кё°кё° лӮҙ мҠӨнҒ¬л Ҳмқҙн•‘мңјлЎң м–ҙл–Ө мӣ№нҺҳмқҙм§Җл“  RSS н”јл“ңлЎң л°”кҝҖ мҲҳ мһҲмҠөлӢҲлӢӨ. мһҗмІҙ н”јл“ңлҘј м ңкіөн•ҳм§Җ м•ҠлҠ” лё”лЎңк·ёлӮҳ мӢұкёҖ нҺҳмқҙм§Җ м•ұм—җ мң мҡ©н•©лӢҲлӢӨ."
