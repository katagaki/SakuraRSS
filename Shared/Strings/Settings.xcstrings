    "ClearThisPage.About" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear This Page ist ein Drittanbieter-Leserdienst, der Werbung und störende Elemente aus Webartikeln entfernt und sie in einem übersichtlichen, ablenkungsfreien Format darstellt. Wenn diese Option für einen Feed aktiviert ist, werden Artikel in einem eingebetteten WebView über https://clearthis.page geöffnet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear This Page is a third-party reader service that strips ads and clutter from web articles, presenting them in a clean, distraction-free format. When enabled for a feed, articles open inside an embedded WebView using https://clearthis.page."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear This Page est un service de lecture tiers qui supprime les publicités et les éléments superflus des articles web, en les présentant dans un format épuré et sans distraction. Lorsqu'il est activé pour un flux, les articles s'ouvrent dans une WebView intégrée utilisant https://clearthis.page."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear This Page è un servizio di lettura di terze parti che rimuove pubblicità ed elementi superflui dagli articoli web, presentandoli in un formato pulito e senza distrazioni. Quando è abilitato per un feed, gli articoli si aprono all'interno di una WebView incorporata utilizzando https://clearthis.page."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear This Pageはサードパーティ製のリーダーサービスで、Web記事から広告や不要な要素を取り除き、すっきりとした気が散らない形式で表示します。フィードで有効にすると、記事は https://clearthis.page を使用した埋め込みWebView内で開きます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear This Page는 웹 기사에서 광고와 잡다한 요소를 제거하여 깔끔하고 방해 없는 형식으로 보여주는 제3자 리더 서비스입니다. 피드에 활성화하면 기사는 https://clearthis.page 를 사용하는 내장 WebView에서 열립니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear This Page là một dịch vụ trình đọc của bên thứ ba giúp loại bỏ quảng cáo và các yếu tố gây rối khỏi các bài viết trên web, trình bày chúng ở định dạng gọn gàng, không gây xao nhãng. Khi được bật cho một nguồn cấp, các bài viết sẽ mở bên trong WebView nhúng sử dụng https://clearthis.page."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear This Page 是一项第三方阅读服务，可去除网页文章中的广告和杂乱内容，以简洁、无干扰的格式呈现。为订阅源启用后，文章将在使用 https://clearthis.page 的嵌入式 WebView 中打开。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear This Page 是一項第三方閱讀服務，可去除網頁文章中的廣告和雜亂內容，以簡潔、無干擾的格式呈現。為訂閱源啟用後，文章將在使用 https://clearthis.page 的嵌入式 WebView 中開啟。"
          }
        }
      }
    },
