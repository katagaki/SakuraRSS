    "ContentInsights.Footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatisch ähnliche Inhalte, Themen, Organisationen und Personen aus Inhalten in Ihrem Feed finden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatically find similar content, topics, organizations, and people from content in your feed."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trouver automatiquement du contenu similaire, des sujets, des organisations et des personnes à partir du contenu de votre flux."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trova automaticamente contenuti simili, argomenti, organizzazioni e persone dai contenuti nel tuo feed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィードのコンテンツから類似コンテンツ、トピック、組織、人物を自動的に検出します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "피드의 콘텐츠에서 유사한 콘텐츠, 주제, 조직, 인물을 자동으로 찾습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tự động tìm nội dung tương tự, chủ đề, tổ chức và nhân vật từ nội dung trong nguồn cấp dữ liệu của bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自动从您的订阅源内容中查找相似内容、话题、组织和人物。"
