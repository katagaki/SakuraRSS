    "ArchivePh.About" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archive.md speichert Momentaufnahmen von Webseiten, die du ohne Paywalls oder Tracking ansehen kannst. Tippe in Artikeln auf Archive.md-Links, um archivierte Seiten zu laden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archive.md saves snapshots of web pages that you can view without paywalls or tracking. Tap Archive.md links in articles to load archived pages."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archive.md enregistre des instantanés de pages web que vous pouvez consulter sans paywall ni suivi. Appuyez sur les liens Archive.md dans les articles pour charger les pages archivées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archive.md salva istantanee di pagine web che puoi visualizzare senza paywall o tracciamento. Tocca i link Archive.md negli articoli per caricare le pagine archiviate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archive.md はウェブページのスナップショットを保存し、ペイウォールやトラッキングなしで閲覧できます。記事内の Archive.md リンクをタップすると、アーカイブされたページを読み込みます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archive.md는 웹 페이지의 스냅샷을 저장하여 유료 장벽이나 추적 없이 볼 수 있습니다. 기사에서 Archive.md 링크를 탭하여 아카이브된 페이지를 로드하세요."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archive.md lưu ảnh chụp các trang web để bạn có thể xem mà không bị tường thu phí hay theo dõi. Nhấn vào liên kết Archive.md trong bài viết để tải trang đã lưu trữ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archive.md 会保存网页的快照，让你可以在没有付费墙或追踪的情况下浏览。在文章中点击 Archive.md 链接以加载已归档的页面。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archive.md 會儲存網頁的快照，讓你可以在沒有付費牆或追蹤的情況下瀏覽。在文章中點擊 Archive.md 連結以載入已歸檔的頁面。"
          }
        }
      }
    },
