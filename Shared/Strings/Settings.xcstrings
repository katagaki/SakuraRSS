    "YouTube.SponsorBlock.Footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überspringt automatisch gesponserte Segmente, Intros, Outros und andere inhaltslose Abschnitte in YouTube-Videos mithilfe von Crowdsourcing-Daten von SponsorBlock."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatically skip sponsored segments, intros, outros, and other non-content sections in YouTube videos using crowd-sourced data from SponsorBlock."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passe automatiquement les segments sponsorisés, intros, outros et autres sections non pertinentes dans les vidéos YouTube en utilisant les données participatives de SponsorBlock."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salta automaticamente i segmenti sponsorizzati, intro, outro e altre sezioni non pertinenti nei video di YouTube utilizzando i dati della community di SponsorBlock."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SponsorBlockのクラウドソーシングデータを使用して、YouTube動画のスポンサーセグメント、イントロ、アウトロなどのコンテンツ以外のセクションを自動的にスキップします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SponsorBlock의 크라우드소싱 데이터를 사용하여 YouTube 동영상에서 스폰서 세그먼트, 인트로, 아웃트로 및 기타 비콘텐츠 섹션을 자동으로 건너뜁니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tự động bỏ qua các đoạn quảng cáo, phần mở đầu, phần kết thúc và các phần không phải nội dung khác trong video YouTube bằng dữ liệu cộng đồng từ SponsorBlock."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用SponsorBlock的众包数据，自动跳过YouTube视频中的赞助片段、片头、片尾和其他非内容部分。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用SponsorBlock的群眾外包資料，自動跳過YouTube影片中的贊助片段、片頭、片尾和其他非內容部分。"
          }
        }
      }
    },
