    "ListRules.AllowedKeywords.Footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur Inhalte mit diesen Schlüsselwörtern werden in dieser Liste angezeigt. Wird nach den Feed-Regeln angewendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only content matching these keywords will appear in this list. Applied after per-feed rules."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seuls les contenus correspondant à ces mots-clés apparaîtront dans cette liste. Appliqué après les règles de flux."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo i contenuti corrispondenti a queste parole chiave appariranno in questa lista. Applicato dopo le regole del feed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらのキーワードに一致するコンテンツのみがこのリストに表示されます。フィードルールの後に適用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 키워드와 일치하는 콘텐츠만 이 리스트에 표시됩니다. 피드 규칙 이후에 적용됩니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chỉ các nội dung khớp với từ khóa này mới xuất hiện trong danh sách. Áp dụng sau quy tắc nguồn cấp."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有匹配这些关键词的内容才会出现在此列表中。在订阅源规则之后应用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有符合這些關鍵字的內容才會出現在此列表中。在訂閱源規則之後套用。"
          }
        }
      }
    },
