    "Transcripts.DeleteAll.ConfirmMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle zwischengespeicherten Podcast-Transkripte von diesem Gerät entfernt. Sie können sie durch erneutes Herunterladen der Episoden regenerieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will remove all cached podcast transcripts from this device. You can regenerate them by re-downloading episodes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera toutes les transcriptions de podcast en cache de cet appareil. Vous pourrez les régénérer en retéléchargeant les épisodes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo rimuoverà tutte le trascrizioni podcast memorizzate da questo dispositivo. Puoi rigenerarle riscaricando gli episodi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この操作により、キャッシュされたすべてのポッドキャスト文字起こしがデバイスから削除されます。エピソードを再ダウンロードすることで再生成できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 기기에서 캐시된 모든 팟캐스트 스크립트가 삭제됩니다. 에피소드를 다시 다운로드하여 재생성할 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thao tác này sẽ xóa tất cả bản chép lời podcast đã lưu trong bộ nhớ đệm khỏi thiết bị này. Bạn có thể tạo lại bằng cách tải xuống lại các tập."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将从此设备中删除所有缓存的播客转录文本。您可以通过重新下载单集来重新生成。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將從此裝置中移除所有快取的Podcast轉錄文字。您可以透過重新下載單集來重新產生。"
          }
        }
      }
    },
