    "DeleteDownload.Message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden die heruntergeladene Episode und das Transkript von Ihrem Gerät entfernt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will remove the downloaded episode and its transcript from your device."
