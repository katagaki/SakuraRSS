    "InstagramProfileFeeds.Footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Folgen Sie Instagram-Profilen als Feeds, indem Sie deren Profil-URLs hinzufügen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Follow Instagram profiles as feeds by adding their profile URLs."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivez des profils Instagram comme flux en ajoutant leurs URLs de profil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segui i profili Instagram come feed aggiungendo i loro URL del profilo."
