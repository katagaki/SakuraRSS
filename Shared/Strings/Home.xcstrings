    "SummaryHeadlines.TopicHintPrefix" : {
      "comment" : "A prefix for the topic hint section of the",
      "extractionState" : "manual",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hinweis nur zur Priorisierung — geben Sie diese Liste niemals als Überschrift aus. Wenn ein heutiges Ereignis eines dieser Themen oder Personen betrifft, bevorzugen Sie es:"
