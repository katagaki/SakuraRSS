    "FeedRules.AllowedKeywords.Footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn erlaubte Stichwörter festgelegt sind, werden nur Inhalte angezeigt, die diese Stichwörter enthalten. Alle anderen werden ausgeblendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When allowed keywords are set, only content containing these keywords will be shown. All other content will be hidden."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque des mots-clés autorisés sont définis, seuls les contenus contenant ces mots-clés seront affichés. Tous les autres contenus seront cachés."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando sono impostate parole chiave consentite, verranno mostrati solo i contenuti che le contengono. Tutti gli altri contenuti verranno nascosti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "許可するキーワードが設定されている場合、これらのキーワードを含むコンテンツのみが表示されます。他のコンテンツはすべて非表示になります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "허용 키워드가 설정되면 해당 키워드가 포함된 콘텐츠만 표시됩니다. 다른 모든 콘텐츠는 숨겨집니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi từ khóa được phép được đặt, chỉ các nội dung chứa các từ khóa này mới được hiển thị. Tất cả các nội dung khác sẽ bị ẩn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置允许的关键词后，只有包含这些关键词的内容才会显示。所有其他内容将被隐藏。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設置允許的關鍵字後，只有包含這些關鍵字的內容才會顯示。所有其他內容將被隱藏。"
          }
        }
      }
