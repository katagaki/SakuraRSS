    "Feature.ViewStyles.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Inhalte in Posteingang-, Feed-, Magazin- und weiteren Layouts durchstöbern"
