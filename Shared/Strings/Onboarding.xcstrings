    "Step.BackgroundRefresh.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte deine Feeds mit automatischen Hintergrund-Updates aktuell."
