    "Cleanup.ConfirmMessage %@" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Inhalte älter als \"%@\" werden dauerhaft gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All content older than \"%@\" will be permanently deleted. This cannot be undone."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tout le contenu datant de plus de « %@ » sera supprimé définitivement. Cette action est irréversible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutti i contenuti più vecchi di \"%@\" verranno eliminati definitivamente. Questa azione non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」より前のコンテンツがすべて完全に削除されます。この操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\"보다 오래된 모든 콘텐츠가 영구적으로 삭제됩니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tất cả nội dung cũ hơn \"%@\" sẽ bị xóa vĩnh viễn. Hành động này không thể hoàn tác."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有早于「%@」的内容将被永久删除。此操作无法撤消。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有早於「%@」的內容將被永久刪除。此操作無法復原。"
          }
        }
      }
    },
