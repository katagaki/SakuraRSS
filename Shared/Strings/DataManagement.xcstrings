    "Logs.Clear.Message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle aufgezeichneten Protokolle dauerhaft gelöscht. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will permanently delete all recorded logs. This action cannot be undone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette action supprimera définitivement tous les journaux enregistrés. Elle est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa operazione eliminerà definitivamente tutti i log registrati. L'azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記録されたすべてのログが完全に削除されます。この操作は取り消せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기록된 모든 로그가 영구적으로 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermee worden alle vastgelegde logboeken permanent verwijderd. Deze actie kan niet ongedaan worden gemaakt."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa vĩnh viễn tất cả nhật ký đã ghi. Không thể hoàn tác."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除所有已记录的日志。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將永久刪除所有已記錄的日誌。此操作無法復原。"
          }
        }
      }
    }
  },
