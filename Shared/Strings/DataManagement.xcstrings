    "Import.ModeMessage": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie die importierten Feeds mit Ihren bestehenden zusammenführen oder alle vorhandenen Feeds ersetzen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Would you like to merge the imported feeds with your existing ones, or replace all existing feeds?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous fusionner les flux importés avec vos flux existants, ou remplacer tous les flux existants ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuoi unire i feed importati con quelli esistenti, o sostituire tutti i feed esistenti?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インポートしたフィードを既存のフィードとマージしますか、それとも既存のフィードをすべて置き換えますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가져온 피드를 기존 피드와 병합하시겠습니까, 아니면 기존 피드를 모두 교체하시겠습니까?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wil je de geïmporteerde feeds samenvoegen met je bestaande feeds, of alle bestaande feeds vervangen?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn muốn hợp nhất các nguồn cấp đã nhập với các nguồn cấp hiện có, hay thay thế tất cả các nguồn cấp hiện có?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你想将导入的订阅源与现有订阅源合并，还是替换所有现有订阅源？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你想將匯入的訂閱源與現有訂閱源合併，還是取代所有現有訂閱源？"
