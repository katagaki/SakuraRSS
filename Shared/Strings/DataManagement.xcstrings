    "Cleanup.Manual.Message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle aus, wie weit zurück Inhalte gelöscht werden sollen. Gelöschte Inhalte können nicht wiederhergestellt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose how far back to delete content. Deleted content cannot be restored."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez jusqu’où supprimer les contenus. Le contenu supprimé ne peut pas être restauré."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli fino a quando eliminare i contenuti. I contenuti eliminati non possono essere ripristinati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どこまで遡ってコンテンツを削除するかを選択してください。削除したコンテンツは復元できません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "콘텐츠를 어디까지 삭제할지 선택하세요. 삭제된 콘텐츠는 복원할 수 없습니다."
          }
        },
        "vi" : {
