    "AddToBookmarks.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Setzt ein Lesezeichen für den angegebenen Inhalt. Gibt „true“ zurück, wenn das Lesezeichen neu hinzugefügt wurde."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bookmarks the given piece of content. Returns true if the bookmark was newly added."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute le contenu donné aux favoris. Renvoie vrai si le favori a été ajouté."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiunge il contenuto fornito ai segnalibri. Restituisce vero se il segnalibro è stato appena aggiunto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "指定されたコンテンツをブックマークに追加します。新しく追加された場合は true を返します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지정된 콘텐츠를 북마크에 추가합니다. 새로 추가된 경우 true를 반환합니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đánh dấu nội dung đã cho. Trả về true nếu dấu trang vừa được thêm."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将给定内容加入书签。新增成功时返回 true。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將指定內容加入書籤。新加入時回傳 true。"
          }
        }
      }
    },
