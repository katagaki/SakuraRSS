    "GetContentText.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Extrahiert den gesamten Text des angegebenen Inhalts als Liste von Blöcken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extracts the full body of the given piece of content as a list of blocks."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Extrait l'intégralité du contenu donné sous forme de liste de blocs."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Estrae l'intero testo del contenuto fornito come elenco di blocchi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "指定されたコンテンツの本文をブロックのリストとして抽出します。"
