{
  "sourceLanguage": "en",
  "strings": {
    "AddFeedFromURL.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abonniert den Feed an der angegebenen URL. Gibt „true“ zurück, wenn der Feed hinzugefügt wurde."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Subscribes to the feed at the given URL. Returns true if the feed was added."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S'abonne au flux à l'URL donnée. Renvoie vrai si le flux a été ajouté."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si iscrive al feed all'URL fornito. Restituisce vero se il feed è stato aggiunto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "指定されたURLのフィードを購読します。追加された場合は true を返します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지정된 URL의 피드를 구독합니다. 추가된 경우 true를 반환합니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đăng ký nguồn cấp tại URL được cung cấp. Trả về true nếu đã thêm."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "订阅给定 URL 的订阅源。添加成功时返回 true。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "訂閱指定 URL 的訂閱源。加入成功時回傳 true。"
          }
        }
      }
    },
