    "GetLatestContent.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gibt den neuesten Inhalt aus einem Feed, einer Liste, einem Thema oder einer Person zurück."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Returns the most recent piece of content from a feed, list, topic, or person."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Renvoie le contenu le plus récent d'un flux, d'une liste, d'un sujet ou d'une personne."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Restituisce il contenuto più recente da un feed, un elenco, un argomento o una persona."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィード、リスト、トピックまたは人物から最新のコンテンツを返します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피드, 목록, 주제 또는 인물에서 가장 최근 콘텐츠를 반환합니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trả về nội dung mới nhất từ một nguồn cấp, danh sách, chủ đề hoặc người."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从订阅源、列表、话题或人物返回最新内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從訂閱源、列表、話題或人物返回最新內容。"
          }
        }
      }
    },
