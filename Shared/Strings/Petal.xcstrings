        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chưa có nguồn cấp web nào. Hãy tạo một nguồn từ màn hình Thêm nguồn cấp, hoặc nhập một gói .srss."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "还没有网页订阅源。可在“添加订阅源”界面创建，或导入 .srss 包。"
          }
        },
